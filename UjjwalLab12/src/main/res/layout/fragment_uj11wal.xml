<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/ujj_space_large">

    <TextView
        android:id="@+id/ujjTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/ujj_full_name_id"
        android:gravity="center"
        android:textColor="@color/red"
        android:textStyle="bold|italic"
        android:textSize="@dimen/ujj_text_large" />

    <EditText
        android:id="@+id/ujjCourseNameInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/ujj_course_name_hint"
        android:inputType="textCapCharacters" />

    <EditText
        android:id="@+id/ujjCourseDescInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/ujj_course_desc_hint"
        android:digits="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ -," />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="@dimen/ujj_space_large">

        <Button
            android:id="@+id/ujjAddBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ujj_add_btn"
            android:layout_marginEnd="@dimen/ujj_space_large"/>

        <Button
            android:id="@+id/ujjDeleteBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ujj_delete_btn"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/ujjRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/ujj_space_large"/>
</LinearLayout>