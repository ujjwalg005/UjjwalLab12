<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/ujj_space_standard"
    android:layout_marginBottom="@dimen/ujj_space_medium"
    android:background="@color/bg_course_row">

    <TextView
        android:id="@+id/ujjRowCourseName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="@dimen/ujj_text_medium" />

    <TextView
        android:id="@+id/ujjRowCourseDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:layout_marginTop="@dimen/ujj_space_small"/>
</LinearLayout>